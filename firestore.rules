rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Whether the signed-in caller is a member of challenges/{challengeId}
    // (the creator is always enrolled as a member at creation, so this
    // also covers "is the creator" without a separate check).
    function isChallengeMember(challengeId) {
      return exists(/databases/$(database)/documents/challenges/$(challengeId)/members/$(request.auth.uid));
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /challenges/{challengeId} {
      // Only members may read a challenge doc by id. Non-members preview a
      // challenge via its invite link through /api/invite/[token], which
      // uses the Admin SDK server-side and returns only public preview
      // fields — so there is no client query to allow here.
      allow get: if request.auth != null && isChallengeMember(challengeId);
      allow list: if false;
      allow create: if request.auth != null;
      // Creator may edit anything; any signed-in user may touch memberCount
      // only (bumped in the same batch that creates their member doc on join)
      allow update: if request.auth != null
        && (resource.data.createdBy == request.auth.uid
          || request.resource.data.diff(resource.data).affectedKeys()
              .hasOnly(['memberCount']));
      allow delete: if request.auth != null
        && resource.data.createdBy == request.auth.uid;

      match /members/{uid} {
        allow read: if request.auth != null && isChallengeMember(challengeId);
        allow write: if request.auth != null && request.auth.uid == uid;
      }

      match /activities/{activityId} {
        allow read: if request.auth != null && isChallengeMember(challengeId);
        // Strava activities are written only by the server (admin SDK via
        // webhook). Clients may log/delete their own manual entries.
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.source == 'manual';
        allow delete: if request.auth != null
          && resource.data.uid == request.auth.uid
          && resource.data.source == 'manual';
        allow update: if false;
      }
    }
  }
}
